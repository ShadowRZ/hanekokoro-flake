{
  "nix.serverSettings": {
    "nixd": {
      "nixpkgs": {
        "expr": "(builtins.getFlake (builtins.toString ./.)).currentSystem._module.args.pkgs"
      },
      "formatting": {
        "command": ["nixfmt"]
      },
      "options": {
        // NixOS
        "nixos": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.mimeow-coffees.options"
        },
        // Home Manager
        "homeManager": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.mimeow-coffees.options.home-manager.users.type.getSubOptions []"
        },
        // Flake Parts
        "flake": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).debug.options"
        },
        // Flake Parts perSystem
        "perSystem": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).currentSystem.options"
        },
        "nixvim": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).packages.${builtins.currentSystem}.nixvim.options"
        }
      }
    }
  },
  "nixEnvPicker.envFile": "${workspaceFolder}${/}flake.nix"
}
